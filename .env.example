# SoniqueBay Environment Configuration

# Database
DATABASE_URL=sqlite:///soniquebay.db

# Redis
REDIS_URL=redis://redis:6379

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# TaskIQ (Migration progressive depuis Celery)
TASKIQ_BROKER_URL=redis://redis:6379/1
TASKIQ_RESULT_BACKEND=redis://redis:6379/1
USE_TASKIQ_FOR_MAINTENANCE=false
USE_TASKIQ_FOR_COVERS=false
USE_TASKIQ_FOR_INSERT=false
USE_TASKIQ_FOR_VECTORIZATION=false
USE_TASKIQ_FOR_METADATA=false
USE_TASKIQ_FOR_BATCH=false
USE_TASKIQ_FOR_SCAN=false
ENABLE_CELERY_FALLBACK=true
WORKER_DIRECT_DB_ENABLED=false

# Last.fm API (Required for artist similarity features)
# Get your API key and secret from: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_API_SECRET=your_lastfm_api_secret_here

# API Configuration
API_URL=http://localhost:8001
RECOMMENDER_API_URL=http://localhost:8002

# Logging
LOG_LEVEL=INFO

# Development
DEBUG=true
TESTING=false