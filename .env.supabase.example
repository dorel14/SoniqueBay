# ============================================
# Configuration Supabase pour SoniqueBay
# ============================================

# === BASE DE DONNÉES ===
SUPABASE_DB_USER=supabase
SUPABASE_DB_PASSWORD=supabase
SUPABASE_DB_NAME=postgres
SUPABASE_DB_PORT=54322

# === JWT & AUTHENTIFICATION ===
# Clé secrète pour signer les tokens JWT (min 32 caractères)
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Clé pour les tokens de service (min 64 caractères)
SUPABASE_SECRET_KEY_BASE=your-super-secret-key-base-with-at-least-64-characters-long

# === TOKENS PRÉ-GÉNÉRÉS (développement) ===
# Ces tokens sont utilisés par défaut en mode développement
# Ne pas modifier sauf si vous régénérez les clés JWT

# Clé anonyme (lecture publique)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNvbnF1ZWJheSIsInJvbGUiOiJhbm9uIiwiaWF0IjoxNjAwMDAwMDAwLCJleHAiOjE5MDAwMDAwMDB9.test

# Clé de service (accès complet)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNvbnF1ZWJheSIsInJvbGUiOiJzZXJ2aWNlX3JvbGUiLCJpYXQiOjE2MDAwMDAwMDAsImV4cCI6MTkwMDAwMDAwMH0.test

# === URLS ===
SUPABASE_URL=http://localhost:54321
SUPABASE_PUBLIC_URL=http://localhost:54321
SUPABASE_SITE_URL=http://localhost:3000

# Redirections autorisées après auth
SUPABASE_REDIRECT_URLS=http://localhost:3000/**

# === FEATURE FLAGS ===
# Activer/désactiver l'utilisation de Supabase
USE_SUPABASE=false

# === DASHBOARD ===
DEFAULT_ORGANIZATION=SoniqueBay
DEFAULT_PROJECT=SoniqueBay
